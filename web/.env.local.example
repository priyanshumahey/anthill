# Hocuspocus collab server (see /collab). The browser connects directly.
NEXT_PUBLIC_HOCUSPOCUS_URL=ws://localhost:8888

# Agent bridge HTTP URL — shown in the "Connect agent" dialog so external
# agents (Claude Code, Copilot, …) know where to point. If unset, derived
# from NEXT_PUBLIC_HOCUSPOCUS_URL by swapping ws→http and 8888→8889.
NEXT_PUBLIC_AGENT_BRIDGE_URL=http://localhost:8889
