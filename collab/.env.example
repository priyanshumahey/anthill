# Hocuspocus collab server
# When running locally with `supabase start`, defaults are:
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Service-role key (NOT publishable) — required to bypass RLS for Yjs persistence.
SUPABASE_SERVICE_ROLE_KEY=

# Port the WebSocket server listens on. Browser connects here directly.
COLLAB_PORT=8888

# CSV of allowed origins (no spaces). Use * for dev.
COLLAB_ALLOWED_ORIGINS=*

# ── Agent bridge (HTTP surface for external agents) ─────────────
# Port the agent bridge HTTP server listens on (separate from Hocuspocus).
AGENT_BRIDGE_PORT=8889

# Shared secret agents must pass as `X-Agent-Token`. Leave empty for OPEN
# MODE (dev only). Set to a long random string in any non-local env.
ANTHILL_AGENT_BRIDGE_SECRET=
